<Window x:Class="Pointframe.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Cursor="Cross"
        ShowInTaskbar="False"
        AutomationProperties.AutomationId="OverlayWindow.Root">

  <Window.Resources>

    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <!-- Annotation tool radio button -->
    <Style x:Key="ToolBtn" TargetType="RadioButton">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Margin" Value="0,1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="1"
                    CornerRadius="4" Padding="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolBtnCheckedBackground}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ToolBtnCheckedBorder}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolBtnHoverBackground}"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsChecked" Value="True"/>
                  <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PressedBackground}"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Action / icon button -->
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="1"
                    CornerRadius="4" Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnHoverBackground}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnPressedBackground}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="RecordingHudActionBtn" TargetType="Button">
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnHoverBackground}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnPressedBackground}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="RecordingHudModeActionBtn" TargetType="Button">
      <Setter Property="Width" Value="60"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{DynamicResource ActionBtnHoverBackground}"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <DataTrigger Binding="{Binding IsAnnotationInputArmed}" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolBtnCheckedBackground}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ToolBtnCheckedBorder}"/>
              </DataTrigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnPressedBackground}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PressedBackground}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FluentActionIconText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FluentToolIconText" TargetType="TextBlock" BasedOn="{StaticResource FluentActionIconText}">
      <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="FluentDangerIconText" TargetType="TextBlock" BasedOn="{StaticResource FluentActionIconText}">
      <Setter Property="Foreground" Value="#D96464"/>
    </Style>

  </Window.Resources>

  <!-- Root canvas — near-transparent so WPF hit-tests it (fully transparent = no hit-test) -->
  <Canvas x:Name="Root" Background="#01000000">

    <!-- Frozen screen snapshot — painted first so the live desktop is never visible -->
    <Image x:Name="ScreenSnapshot" Stretch="Fill"/>

    <!-- ── Phase 2: four dim strips around the selection ── -->
    <Rectangle x:Name="DimTop"    Fill="#80000000" Visibility="Collapsed"/>
    <Rectangle x:Name="DimBottom" Fill="#80000000" Visibility="Collapsed"/>
    <Rectangle x:Name="DimLeft"   Fill="#80000000" Visibility="Collapsed"/>
    <Rectangle x:Name="DimRight"  Fill="#80000000" Visibility="Collapsed"/>

    <!-- Dashed selection border (both phases) -->
    <Rectangle x:Name="SelectionBorder"
               Stroke="White" StrokeThickness="1.5"
               StrokeDashArray="5,3"
               Fill="Transparent"
               Panel.ZIndex="20"
               IsHitTestVisible="False"
               Visibility="Hidden"/>

    <Rectangle x:Name="RecordingBorderWhite"
               Fill="Transparent"
               Stroke="White"
               StrokeThickness="2"
               Visibility="Collapsed"
               IsHitTestVisible="False">
      <Rectangle.StrokeDashArray>
        <DoubleCollection>6 6</DoubleCollection>
      </Rectangle.StrokeDashArray>
    </Rectangle>

    <Rectangle x:Name="RecordingBorderBlack"
               Fill="Transparent"
               Stroke="Black"
               StrokeThickness="2"
               StrokeDashOffset="6"
               Visibility="Collapsed"
               IsHitTestVisible="False">
      <Rectangle.StrokeDashArray>
        <DoubleCollection>6 6</DoubleCollection>
      </Rectangle.StrokeDashArray>
    </Rectangle>

    <Canvas x:Name="RecordingAnnotationCanvas"
            Background="#01000000"
            Visibility="Collapsed"/>

    <!-- OCR text lasso rectangle (visible during text lasso drag) -->
    <Rectangle x:Name="OcrLassoRect"
               Stroke="#0078D4" StrokeThickness="1.5"
               StrokeDashArray="4,3"
               Fill="{DynamicResource OcrLassoFill}"
               Panel.ZIndex="30"
               IsHitTestVisible="False"
               Visibility="Collapsed"/>

    <!-- Annotation drawing surface (phase 2, sized over the selection) -->
    <Canvas x:Name="AnnotationCanvas"
            Background="#01000000"
            Visibility="Collapsed"
            AutomationProperties.AutomationId="OverlayWindow.AnnotationCanvas"/>

    <!-- Vertical annotation toolbar (phase 2, floats right of selection) -->
    <Border x:Name="AnnotToolbar"
            Background="{DynamicResource ToolbarBackground}" CornerRadius="6"
            BorderBrush="{DynamicResource ToolbarBorder}" BorderThickness="1"
            Padding="4,6" Visibility="Collapsed"
            AutomationProperties.AutomationId="OverlayWindow.AnnotationToolbar">
      <Border.Effect>
        <DropShadowEffect Color="#444444" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
      </Border.Effect>
      <StackPanel Orientation="Vertical">

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Arrow" Click="Tool_Click" ToolTip="Arrow">
          <Viewbox Width="15" Height="15">
            <Canvas Width="16" Height="16">
              <Path Data="M2.5,13.5 L11.2,4.8"
                    Stroke="{DynamicResource PrimaryText}"
                    StrokeThickness="1.7"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"/>
              <Path Data="M9.1,4.8 H13.4 V9.1"
                    Stroke="{DynamicResource PrimaryText}"
                    StrokeThickness="1.7"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"/>
            </Canvas>
          </Viewbox>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Line" Click="Tool_Click" ToolTip="Line">
          <Viewbox Width="15" Height="15">
            <Canvas Width="16" Height="16">
              <Path Data="M3,13 L13,3"
                    Stroke="{DynamicResource PrimaryText}"
                    StrokeThickness="1.8"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"/>
            </Canvas>
          </Viewbox>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool" IsChecked="True"
                     Tag="Rectangle" Click="Tool_Click" ToolTip="Rectangle">
          <Border Width="16" Height="12" BorderBrush="{DynamicResource SubLabelText}" BorderThickness="1.5" Background="Transparent"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Circle" Click="Tool_Click" ToolTip="Circle">
          <Ellipse Width="14" Height="14" Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.5" Fill="Transparent"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Pen" Click="Tool_Click" ToolTip="Pen">
          <TextBlock Text="&#xE70F;" Style="{StaticResource FluentToolIconText}"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Highlight" Click="Tool_Click" ToolTip="Highlight">
          <Border Width="18" Height="8" Background="#99FFFF00"
                  BorderBrush="#A09010" BorderThickness="1" CornerRadius="1"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Text" Click="Tool_Click" ToolTip="Text">
          <TextBlock Text="A" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Number" Click="Tool_Click" ToolTip="Place numbered label">
          <Border Width="16" Height="16" BorderBrush="{DynamicResource PrimaryText}" BorderThickness="1.4" CornerRadius="8" Background="Transparent">
            <TextBlock Text="1" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Blur" Click="Tool_Click" ToolTip="Blur / Pixelate">
          <UniformGrid Rows="3" Columns="3" Width="15" Height="15">
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.8"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
            <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
          </UniformGrid>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Callout" Click="Tool_Click" ToolTip="Callout / Speech bubble">
          <Viewbox Width="15" Height="15">
            <Canvas Width="16" Height="16">
              <Path Data="M3.5,3 H12.5 C13.33,3 14,3.67 14,4.5 V9 C14,9.83 13.33,10.5 12.5,10.5 H8.5 L5.5,13.5 V10.5 H3.5 C2.67,10.5 2,9.83 2,9 V4.5 C2,3.67 2.67,3 3.5,3 Z"
                    Stroke="{DynamicResource PrimaryText}"
                    StrokeThickness="1.3"
                    Fill="Transparent"
                    StrokeLineJoin="Round"/>
            </Canvas>
          </Viewbox>
        </RadioButton>

        <!-- Divider -->
        <Rectangle Height="1" Fill="{DynamicResource DividerColor}" Margin="4,5"/>

        <!-- Color swatch -->
        <Button Width="34" Height="34" Cursor="Hand"
          Style="{StaticResource ActionBtn}"
          Command="{Binding PickColorCommand}" ToolTip="Colour">
          <Ellipse Width="20" Height="20" Fill="{Binding ActiveBrush}"/>
        </Button>

      </StackPanel>
    </Border>

    <!-- Horizontal action bar (phase 2, floats below selection) -->
    <Border x:Name="ActionBar"
            Background="{DynamicResource ToolbarBackground}" CornerRadius="6"
            BorderBrush="{DynamicResource ToolbarBorder}" BorderThickness="1"
            Padding="6,4" Visibility="Collapsed"
            AutomationProperties.AutomationId="OverlayWindow.ActionBar">
      <Border.Effect>
        <DropShadowEffect Color="#444444" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
      </Border.Effect>
      <StackPanel Orientation="Horizontal">

        <Button Style="{StaticResource ActionBtn}"
                x:Name="RecordBtn"
                Click="Record_Click" ToolTip="Record region to video"
                AutomationProperties.AutomationId="OverlayWindow.Record">
          <StackPanel>
            <Ellipse Width="11" Height="11" Fill="#FF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="Record" FontSize="8" Foreground="{DynamicResource SubLabelText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)">
          <StackPanel>
            <TextBlock Text="&#xE7A7;" Style="{StaticResource FluentActionIconText}"/>
            <TextBlock Text="Undo" FontSize="8" Foreground="{DynamicResource SubLabelText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)">
          <StackPanel>
            <TextBlock Text="&#xE7A6;" Style="{StaticResource FluentActionIconText}"/>
            <TextBlock Text="Redo" FontSize="8" Foreground="{DynamicResource SubLabelText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
          Command="{Binding CopyCommand}" ToolTip="Copy to clipboard (Ctrl+C)"
          AutomationProperties.AutomationId="OverlayWindow.Copy">
          <StackPanel>
            <TextBlock Text="&#xE8C8;" Style="{StaticResource FluentActionIconText}"/>
            <TextBlock Text="Copy" FontSize="8" Foreground="{DynamicResource SubLabelText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding CopyTextCommand}" ToolTip="Copy text from screenshot (OCR)">
          <StackPanel>
            <Border Width="15" Height="15" BorderBrush="{DynamicResource PrimaryText}" BorderThickness="1.2" CornerRadius="1.5" HorizontalAlignment="Center">
              <Grid>
                <Rectangle Width="6" Height="1.2" Fill="{DynamicResource PrimaryText}" VerticalAlignment="Top" Margin="0,3.2,0,0"/>
                <Rectangle Width="6" Height="1.2" Fill="{DynamicResource PrimaryText}" VerticalAlignment="Top" Margin="0,6.3,0,0"/>
                <TextBlock Text="A" FontSize="7" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
              </Grid>
            </Border>
            <TextBlock Text="Text" FontSize="8" Foreground="{DynamicResource SubLabelText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding PinCommand}" ToolTip="Pin to screen"
                AutomationProperties.AutomationId="OverlayWindow.Pin">
          <StackPanel>
            <Viewbox Width="15" Height="15">
              <Canvas Width="16" Height="16">
                <Path Data="M5.5,2.5 H10.5 L11.8,5.2 L8.7,6.8 V10.7 L7,13.5 L5.3,10.7 V6.8 L2.2,5.2 Z"
                      Stroke="{DynamicResource PrimaryText}"
                      StrokeThickness="1.3"
                      Fill="Transparent"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
              </Canvas>
            </Viewbox>
            <TextBlock Text="Pin" FontSize="8" Foreground="{DynamicResource SubLabelText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Click="CloseBtn_Click" ToolTip="Close (Esc)"
                AutomationProperties.AutomationId="OverlayWindow.Close">
          <StackPanel>
            <TextBlock Text="&#xE711;" Style="{StaticResource FluentActionIconText}"/>
            <TextBlock Text="Close" FontSize="8" Foreground="{DynamicResource SubLabelText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

      </StackPanel>
    </Border>

    <Border x:Name="CompactActionBar"
            Background="{DynamicResource ToolbarBackground}" CornerRadius="6"
            BorderBrush="{DynamicResource ToolbarBorder}" BorderThickness="1"
            Padding="4" Visibility="Collapsed"
            AutomationProperties.AutomationId="OverlayWindow.CompactActionBar">
      <Border.Effect>
        <DropShadowEffect Color="#444444" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
      </Border.Effect>
      <StackPanel Orientation="Horizontal">

        <Button Style="{StaticResource ActionBtn}"
                x:Name="CompactRecordBtn"
                Click="Record_Click" ToolTip="Record region to video"
                AutomationProperties.AutomationId="OverlayWindow.CompactRecord">
          <Ellipse Width="11" Height="11" Fill="#FF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)">
          <TextBlock Text="&#xE7A7;" Style="{StaticResource FluentActionIconText}"/>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)">
          <TextBlock Text="&#xE7A6;" Style="{StaticResource FluentActionIconText}"/>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding CopyCommand}" ToolTip="Copy to clipboard (Ctrl+C)"
                AutomationProperties.AutomationId="OverlayWindow.CompactCopy">
          <TextBlock Text="&#xE8C8;" Style="{StaticResource FluentActionIconText}"/>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding CopyTextCommand}" ToolTip="Copy text from screenshot (OCR)">
          <Border Width="15" Height="15" BorderBrush="{DynamicResource PrimaryText}" BorderThickness="1.2" CornerRadius="1.5" HorizontalAlignment="Center">
            <Grid>
              <Rectangle Width="6" Height="1.2" Fill="{DynamicResource PrimaryText}" VerticalAlignment="Top" Margin="0,3.2,0,0"/>
              <Rectangle Width="6" Height="1.2" Fill="{DynamicResource PrimaryText}" VerticalAlignment="Top" Margin="0,6.3,0,0"/>
              <TextBlock Text="A" FontSize="7" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
            </Grid>
          </Border>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding PinCommand}" ToolTip="Pin to screen"
                AutomationProperties.AutomationId="OverlayWindow.CompactPin">
          <Viewbox Width="15" Height="15">
            <Canvas Width="16" Height="16">
              <Path Data="M5.5,2.5 H10.5 L11.8,5.2 L8.7,6.8 V10.7 L7,13.5 L5.3,10.7 V6.8 L2.2,5.2 Z"
                    Stroke="{DynamicResource PrimaryText}"
                    StrokeThickness="1.3"
                    Fill="Transparent"
                    StrokeLineJoin="Round"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"/>
            </Canvas>
          </Viewbox>
        </Button>

        <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Click="CloseBtn_Click" ToolTip="Close (Esc)"
                AutomationProperties.AutomationId="OverlayWindow.CompactClose">
          <TextBlock Text="&#xE711;" Style="{StaticResource FluentActionIconText}"/>
        </Button>

      </StackPanel>
    </Border>

    <!-- OCR toast notification -->
    <Border x:Name="OcrToast"
            Background="#DD333333" CornerRadius="6"
            Padding="12,6" Visibility="Collapsed">
      <TextBlock x:Name="OcrToastText"
                 Foreground="White" FontSize="12"
                 FontFamily="Segoe UI" FontWeight="SemiBold"/>
    </Border>

    <Border x:Name="RecordingHudPanel"
            Background="{DynamicResource ToolbarBackground}"
            CornerRadius="6"
            BorderBrush="{DynamicResource ToolbarBorder}"
            BorderThickness="1"
            Padding="6,4"
            Visibility="Collapsed"
            SizeChanged="RecordingHudPanel_SizeChanged">
      <Border.Effect>
        <DropShadowEffect Color="#444444" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
      </Border.Effect>
      <StackPanel Orientation="Vertical">

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource RecordingHudModeActionBtn}"
                    Command="{Binding ToggleAnnotationInputCommand}"
                    ToolTip="Switch between drawing and interacting with the app"
                    Visibility="{Binding CanToggleAnnotation, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="&#xE70F;" Style="{StaticResource FluentActionIconText}"/>
            </Button>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="{Binding CurrentModeLabel}"
                       FontSize="8"
                       Foreground="{DynamicResource SubLabelText}"
                       TextAlignment="Center"
                       Margin="0,2,0,0"
                       Visibility="{Binding CanToggleAnnotation, Converter={StaticResource BoolToVisibility}}"/>

            <Rectangle Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="1"
                       Width="1"
                       Fill="{DynamicResource DividerColor}"
                       Margin="3,7"
                       VerticalAlignment="Stretch"
                       Visibility="{Binding CanToggleAnnotation, Converter={StaticResource BoolToVisibility}}"/>

            <Button Grid.Row="0"
                    Grid.Column="2"
                    Style="{StaticResource RecordingHudActionBtn}"
                    Command="{Binding PauseResumeCommand}"
                    IsEnabled="{Binding CanPauseResume}"
                    ToolTip="Pause or resume recording">
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource FluentActionIconText}">
                    <Setter Property="Text" Value="&#xE769;"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding PauseResumeLabel}" Value="▶ Resume">
                        <Setter Property="Text" Value="&#xE768;"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Button>

            <TextBlock Grid.Row="1"
                       Grid.Column="2"
                       FontSize="8"
                       Foreground="{DynamicResource SubLabelText}"
                       TextAlignment="Center"
                       Margin="0,2,0,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="Pause"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding PauseResumeLabel}" Value="▶ Resume">
                      <Setter Property="Text" Value="Resume"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <Rectangle Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="3"
                       Width="1"
                       Fill="{DynamicResource DividerColor}"
                       Margin="3,7"
                       VerticalAlignment="Stretch"/>

            <Button Grid.Row="0"
                    Grid.Column="4"
                    Style="{StaticResource RecordingHudActionBtn}"
                    Command="{Binding StopCommand}"
                    ToolTip="Stop recording">
              <TextBlock Text="&#xE71A;" Style="{StaticResource FluentDangerIconText}"/>
            </Button>

            <TextBlock Grid.Row="1"
                       Grid.Column="4"
                       Text="Stop"
                       FontSize="8"
                       Foreground="{DynamicResource SubLabelText}"
                       TextAlignment="Center"
                       Margin="0,2,0,0"/>
          </Grid>

          <Border Grid.Column="1"
                  Background="{DynamicResource ActionBtnHoverBackground}"
                  CornerRadius="4"
                  Padding="10,0"
                  MinWidth="64"
                  Height="32"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Right">
            <TextBlock Text="{Binding ElapsedText}"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="13"
                       FontFamily="Segoe UI"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
        </Grid>

        <Rectangle Height="1"
                   Fill="{DynamicResource DividerColor}"
                   Margin="0,6,0,0"
                   Visibility="{Binding IsAnnotationPanelVisible, Converter={StaticResource BoolToVisibility}}"/>

        <Grid Margin="0,6,0,0"
              Visibility="{Binding IsAnnotationPanelVisible, Converter={StaticResource BoolToVisibility}}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
            <RadioButton Style="{StaticResource ToolBtn}"
                         GroupName="RecordingAnnotTool"
                         Tag="Pen"
                         IsChecked="True"
                         Checked="RecordingToolButton_Checked"
                         ToolTip="Pen">
              <TextBlock Text="&#xE70F;" Style="{StaticResource FluentToolIconText}"/>
            </RadioButton>

            <RadioButton Style="{StaticResource ToolBtn}"
                         GroupName="RecordingAnnotTool"
                         Tag="Arrow"
                         Checked="RecordingToolButton_Checked"
                         ToolTip="Arrow">
              <Viewbox Width="15" Height="15">
                <Canvas Width="16" Height="16">
                  <Path Data="M2.5,13.5 L11.2,4.8"
                        Stroke="{DynamicResource PrimaryText}"
                        StrokeThickness="1.7"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"/>
                  <Path Data="M9.1,4.8 H13.4 V9.1"
                        Stroke="{DynamicResource PrimaryText}"
                        StrokeThickness="1.7"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"/>
                </Canvas>
              </Viewbox>
            </RadioButton>

            <RadioButton Style="{StaticResource ToolBtn}"
                         GroupName="RecordingAnnotTool"
                         Tag="Rectangle"
                         Checked="RecordingToolButton_Checked"
                         ToolTip="Rectangle">
              <Border Width="16" Height="12" BorderBrush="{DynamicResource SubLabelText}" BorderThickness="1.5" Background="Transparent"/>
            </RadioButton>

            <RadioButton Style="{StaticResource ToolBtn}"
                         GroupName="RecordingAnnotTool"
                         Tag="Text"
                         Checked="RecordingToolButton_Checked"
                         ToolTip="Text">
              <TextBlock Text="A" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"/>
            </RadioButton>

            <RadioButton Style="{StaticResource ToolBtn}"
                         GroupName="RecordingAnnotTool"
                         Tag="Blur"
                         Checked="RecordingToolButton_Checked"
                         ToolTip="Blur / Redact">
              <UniformGrid Rows="3" Columns="3" Width="15" Height="15">
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.8"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.5"/>
                <Rectangle Margin="0.6" RadiusX="0.6" RadiusY="0.6" Fill="{DynamicResource PrimaryText}" Opacity="0.25"/>
              </UniformGrid>
            </RadioButton>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="8,0,0,0" HorizontalAlignment="Right">
            <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

            <Button Style="{StaticResource RecordingHudActionBtn}"
                    Command="{Binding UndoAnnotationsCommand}"
                    ToolTip="Undo annotation">
              <TextBlock Text="&#xE7A7;" Style="{StaticResource FluentActionIconText}"/>
            </Button>

            <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

            <Button Style="{StaticResource RecordingHudActionBtn}"
                    Command="{Binding ClearAnnotationsCommand}"
                    ToolTip="Clear annotations">
              <TextBlock Text="&#xE711;" Style="{StaticResource FluentDangerIconText}"/>
            </Button>
          </StackPanel>
        </Grid>

      </StackPanel>
    </Border>

  </Canvas>

  <Window.Triggers>
    <EventTrigger RoutedEvent="Loaded">
      <BeginStoryboard>
        <Storyboard RepeatBehavior="Forever">
          <DoubleAnimation Storyboard.TargetName="RecordingBorderWhite"
                           Storyboard.TargetProperty="StrokeDashOffset"
                           From="0"
                           To="-12"
                           Duration="0:0:0.5"/>
          <DoubleAnimation Storyboard.TargetName="RecordingBorderBlack"
                           Storyboard.TargetProperty="StrokeDashOffset"
                           From="6"
                           To="-6"
                           Duration="0:0:0.5"/>
        </Storyboard>
      </BeginStoryboard>
    </EventTrigger>
  </Window.Triggers>
</Window>
