<Window x:Class="Pointframe.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:models="clr-namespace:Pointframe.Models"
        Title="Settings"
        Width="1100"
        Height="760"
        MinWidth="780"
        MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBackground}"
        AutomationProperties.AutomationId="SettingsWindow.Root">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <Style x:Key="PageDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="GroupCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <Style x:Key="GroupDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="RowTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <Style x:Key="RowDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedText}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <Style x:Key="SidebarListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="SidebarListItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentBackground}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{DynamicResource BtnSecondaryBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="20,5"/>
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="20,5"/>
            <Setter Property="Background" Value="{DynamicResource BtnSecondaryBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>

        <Style x:Key="SidebarTitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <Style x:Key="SidebarDescriptionText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedText}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource SurfaceBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="Settings" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="Choose how capture, recording, annotations, and updates behave."
                               Style="{StaticResource PageDescription}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Sections}"
                         SelectedValue="{Binding SelectedSection}"
                         Style="{StaticResource SidebarListBox}"
                         SelectionChanged="SectionNavigation_SelectionChanged"
                         AutomationProperties.AutomationId="SettingsWindow.SectionNavigation">
                    <ListBox.SelectedValuePath>Section</ListBox.SelectedValuePath>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarListItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Section}" Value="{x:Static models:SettingsSection.Capture}">
                                    <Setter Property="AutomationProperties.AutomationId" Value="SettingsWindow.Section.Capture"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Section}" Value="{x:Static models:SettingsSection.Recording}">
                                    <Setter Property="AutomationProperties.AutomationId" Value="SettingsWindow.Section.Recording"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Section}" Value="{x:Static models:SettingsSection.Annotation}">
                                    <Setter Property="AutomationProperties.AutomationId" Value="SettingsWindow.Section.Annotation"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Section}" Value="{x:Static models:SettingsSection.App}">
                                    <Setter Property="AutomationProperties.AutomationId" Value="SettingsWindow.Section.App"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SidebarTitleText}"/>
                                <TextBlock Text="{Binding Description}"
                                           Style="{StaticResource SidebarDescriptionText}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="ContentScrollViewer"
                      Grid.Row="0"
                      Grid.Column="2"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel Margin="0,0,0,12" LastChildFill="False">
                    <Button DockPanel.Dock="Right"
                            Content="Reset this category"
                            Style="{StaticResource SecondaryBtn}"
                            Command="{Binding ResetCurrentSectionCommand}"
                            AutomationProperties.AutomationId="SettingsWindow.ResetCurrentSection"/>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding SelectedSectionItem.DisplayName}" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="{Binding SelectedSectionItem.Description}"
                                   Style="{StaticResource PageDescription}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </DockPanel>

                <StackPanel Visibility="{Binding IsCaptureSectionSelected, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.AutomationId="SettingsWindow.CaptureContent">
                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Storage" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="Choose where screenshots go and whether copied captures are also saved."
                                       Style="{StaticResource GroupDescription}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Screenshot save folder" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Used for auto-saved screenshots and manual saves."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <Grid Grid.Row="0" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ScreenshotSavePath, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1"
                                            Content="Browse..."
                                            Style="{StaticResource BrowseBtn}"
                                            Command="{Binding BrowseScreenshotPathCommand}"
                                            Margin="10,0,0,0"/>
                                </Grid>

                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        Background="{DynamicResource DividerColor}"
                                        Margin="0,16,0,16"/>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Auto-save on copy" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Save a file automatically when you copy a screenshot."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <CheckBox Grid.Row="2"
                                          Grid.Column="1"
                                          Content="Save copied screenshots automatically"
                                          IsChecked="{Binding AutoSaveScreenshots}"
                                          VerticalAlignment="Center"
                                          AutomationProperties.AutomationId="SettingsWindow.AutoSaveScreenshots"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Behavior" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="Control how capture starts and how quickly you can trigger it."
                                       Style="{StaticResource GroupDescription}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Capture delay" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Wait before the overlay opens so menus and hover states stay visible."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          Width="140"
                                          Style="{StaticResource CompactComboBox}"
                                          SelectedItem="{Binding CaptureDelaySeconds}">
                                    <sys:Int32>0</sys:Int32>
                                    <sys:Int32>3</sys:Int32>
                                    <sys:Int32>5</sys:Int32>
                                    <sys:Int32>10</sys:Int32>
                                </ComboBox>

                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        Background="{DynamicResource DividerColor}"
                                        Margin="0,16,0,16"/>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Capture hotkey" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Choose the key that opens the capture overlay."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRecordingHotkey}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Border Background="{DynamicResource KbdBadgeBackground}"
                                                BorderBrush="{DynamicResource KbdBadgeBorder}"
                                                BorderThickness="1,1,1,3"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding RegionCaptureHotkeyDisplayName}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                        </Border>
                                        <Button Content="Change"
                                                Style="{StaticResource BrowseBtn}"
                                                Command="{Binding StartRecordingHotkeyCommand}"
                                                Margin="0,0,6,0"/>
                                        <Button Content="Reset key"
                                                Style="{StaticResource BrowseBtn}"
                                                Command="{Binding ResetHotkeyCommand}"/>
                                    </StackPanel>

                                    <StackPanel x:Name="HotkeyRecordingPanel"
                                                Orientation="Horizontal"
                                                Focusable="True"
                                                Margin="0,10,0,0"
                                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                                IsVisibleChanged="HotkeyRecordingPanel_IsVisibleChanged">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRecordingHotkey}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Border BorderBrush="{DynamicResource HotkeyRecordingBorder}"
                                                BorderThickness="2"
                                                CornerRadius="4"
                                                Padding="10,6"
                                                Background="{DynamicResource HotkeyRecordingBackground}">
                                            <TextBlock Text="Press a key... Esc to cancel"
                                                       Foreground="{DynamicResource HotkeyRecordingText}"
                                                       FontStyle="Italic"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding IsRecordingSectionSelected, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.AutomationId="SettingsWindow.RecordingContent">
                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Output" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="Control where recordings are saved and which format is used by default."
                                       Style="{StaticResource GroupDescription}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Recording output folder" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="The default save location for new MP4 recordings."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <Grid Grid.Row="0" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding RecordingOutputPath, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1"
                                            Content="Browse..."
                                            Style="{StaticResource BrowseBtn}"
                                            Command="{Binding BrowseRecordingPathCommand}"
                                            Margin="10,0,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Pointer effects" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="Help viewers follow your mouse without cluttering the recording."
                                       Style="{StaticResource GroupDescription}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Cursor highlight" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Add a visible ring around the cursor while recording."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1">
                                    <CheckBox Content="Enable cursor highlight"
                                              IsChecked="{Binding RecordingCursorHighlightEnabled}"/>
                                    <StackPanel Margin="24,10,0,0"
                                                Visibility="{Binding RecordingCursorHighlightEnabled, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Highlight size" Style="{StaticResource RowDescription}" Margin="0"/>
                                        <TextBox Width="80"
                                                 Margin="0,6,0,0"
                                                 Text="{Binding RecordingCursorHighlightSize, UpdateSourceTrigger=PropertyChanged}"
                                                 PreviewTextInput="DoubleInput_PreviewTextInput"
                                                 DataObject.Pasting="DoubleInput_Pasting"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        Background="{DynamicResource DividerColor}"
                                        Margin="0,16,0,16"/>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Click ripple" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Show a ripple effect when you click during recording."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <CheckBox Grid.Row="2"
                                          Grid.Column="1"
                                          Content="Enable click ripple"
                                          IsChecked="{Binding RecordingClickRippleEnabled}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Advanced" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="Keep less frequently changed recording defaults out of the main path."
                                       Style="{StaticResource GroupDescription}"/>

                            <Expander Header="Show advanced options"
                                      Margin="0,16,0,0"
                                      Foreground="{DynamicResource PrimaryText}"
                                      AutomationProperties.AutomationId="SettingsWindow.RecordingAdvanced">
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Microphone" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="Record microphone audio alongside the screen capture when a recording starts."
                                                   Style="{StaticResource RowDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Row="0"
                                              Grid.Column="1"
                                              Content="Include microphone audio"
                                              IsChecked="{Binding RecordMicrophone}"
                                              VerticalAlignment="Center"/>

                                    <Border Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Height="1"
                                            Background="{DynamicResource DividerColor}"
                                            Margin="0,16,0,16"/>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Microphone device" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="Choose which Windows input device is used when microphone recording is enabled."
                                               Style="{StaticResource RowDescription}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1">
                                        <ComboBox Width="260"
                                              Style="{StaticResource CompactComboBox}"
                                              ItemsSource="{Binding AvailableMicrophoneDevices}"
                                              SelectedItem="{Binding SelectedMicrophoneDeviceName}"
                                              IsEnabled="{Binding RecordMicrophone}"/>
                                        <TextBlock Margin="0,6,0,0"
                                               Text="No compatible microphone devices were found on this machine."
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="11"
                                               TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource RowDescription}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAvailableMicrophoneDevices}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <Border Grid.Row="3"
                                            Grid.ColumnSpan="2"
                                            Height="1"
                                            Background="{DynamicResource DividerColor}"
                                            Margin="0,16,0,16"/>

                                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="GIF export FPS" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="Lower values make smaller files; higher values look smoother."
                                                   Style="{StaticResource RowDescription}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Row="4"
                                              Grid.Column="1"
                                              Width="140"
                                              Style="{StaticResource CompactComboBox}"
                                              SelectedItem="{Binding GifFps}">
                                        <sys:Int32>5</sys:Int32>
                                        <sys:Int32>8</sys:Int32>
                                        <sys:Int32>10</sys:Int32>
                                        <sys:Int32>15</sys:Int32>
                                        <sys:Int32>20</sys:Int32>
                                    </ComboBox>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding IsAnnotationSectionSelected, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.AutomationId="SettingsWindow.AnnotationContent">
                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Defaults" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="Choose the look new annotation tools start with."
                                       Style="{StaticResource GroupDescription}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Default annotation color" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Used when the annotation toolbar opens."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="36"
                                            Height="28"
                                            BorderBrush="{DynamicResource ControlBorder}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Background="{Binding ColorPreviewBrush}"/>
                                    <Button Content="Change..."
                                            Style="{StaticResource BrowseBtn}"
                                            Command="{Binding PickAnnotationColorCommand}"
                                            Margin="10,0,0,0"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        Background="{DynamicResource DividerColor}"
                                        Margin="0,16,0,16"/>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Stroke thickness" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="The default width for pens, shapes, and highlights."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Width="80"
                                         Text="{Binding DefaultStrokeThickness, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewTextInput="DoubleInput_PreviewTextInput"
                                         DataObject.Pasting="DoubleInput_Pasting"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Preview" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="See the current annotation defaults before saving."
                                       Style="{StaticResource GroupDescription}"/>
                            <Border Margin="0,16,0,0"
                                    Padding="14"
                                    Background="{DynamicResource InputBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="16"
                                                 Height="16"
                                                 Fill="{Binding ColorPreviewBrush}"
                                                 Margin="0,0,12,0"/>
                                        <Rectangle Width="160"
                                                   Height="{Binding AnnotationPreviewThickness}"
                                                   Fill="{Binding ColorPreviewBrush}"
                                                   RadiusX="1"
                                                   RadiusY="1"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Sample stroke"
                                               Style="{StaticResource RowDescription}"
                                               Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding IsAppSectionSelected, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.AutomationId="SettingsWindow.AppContent">
                    <Border Style="{StaticResource GroupCard}">
                        <StackPanel>
                            <TextBlock Text="Appearance and updates" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Text="Preview the app theme and choose how often updates are checked."
                                       Style="{StaticResource GroupDescription}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Theme" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Preview immediately and keep it only when you save."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          Width="180"
                                          Style="{StaticResource CompactComboBox}"
                                          SelectedValue="{Binding AppTheme}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="Follow system" Tag="{x:Static models:AppTheme.System}"/>
                                    <ComboBoxItem Content="Light" Tag="{x:Static models:AppTheme.Light}"/>
                                    <ComboBoxItem Content="Dark" Tag="{x:Static models:AppTheme.Dark}"/>
                                </ComboBox>

                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        Background="{DynamicResource DividerColor}"
                                        Margin="0,16,0,16"/>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Automatic update checks" Style="{StaticResource RowTitle}"/>
                                    <TextBlock Text="Choose how often the app checks GitHub Releases for updates."
                                               Style="{StaticResource RowDescription}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <ComboBox x:Name="UpdateIntervalComboBox"
                                              Width="180"
                                              Style="{StaticResource CompactComboBox}"
                                              SelectedValue="{Binding AutoUpdateCheckInterval}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Never" Tag="{x:Static models:UpdateCheckInterval.Never}"/>
                                        <ComboBoxItem Content="Every day" Tag="{x:Static models:UpdateCheckInterval.EveryDay}"/>
                                        <ComboBoxItem Content="Every 2 days" Tag="{x:Static models:UpdateCheckInterval.EveryTwoDays}"/>
                                        <ComboBoxItem Content="Every 3 days" Tag="{x:Static models:UpdateCheckInterval.EveryThreeDays}"/>
                                    </ComboBox>
                                    <TextBlock Text="Automatic update checks are disabled. You may miss important fixes."
                                               Foreground="{DynamicResource WarningText}"
                                               FontSize="10"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AutoUpdateCheckInterval}"
                                                                 Value="{x:Static models:UpdateCheckInterval.Never}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Restore defaults"
                    Style="{StaticResource SecondaryBtn}"
                    Command="{Binding RestoreDefaultsCommand}"
                    AutomationProperties.AutomationId="SettingsWindow.RestoreDefaults"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryBtn}"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"
                        AutomationProperties.AutomationId="SettingsWindow.Cancel"/>
                <Button Content="Save"
                        Style="{StaticResource PrimaryBtn}"
                        Command="{Binding SaveCommand}"
                        AutomationProperties.AutomationId="SettingsWindow.Save"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
