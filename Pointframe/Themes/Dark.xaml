<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Window / surface ── -->
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="SurfaceBorder" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="InputBackground" Color="#252525"/>

    <!-- ── Controls ── -->
    <SolidColorBrush x:Key="ControlBackground" Color="#2F2F2F"/>
    <SolidColorBrush x:Key="ControlBorder" Color="#555555"/>
    <SolidColorBrush x:Key="HoverBackground" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="PressedBackground" Color="#0D3A60"/>
    <SolidColorBrush x:Key="BtnSecondaryBackground" Color="#333333"/>
    <SolidColorBrush x:Key="DividerColor" Color="#3C3C3C"/>

    <!-- ── Text ── -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="MutedText" Color="#999999"/>
    <SolidColorBrush x:Key="SubLabelText" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="WarningText" Color="#FF9955"/>

    <!-- ── Accent ── -->
    <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentBackground" Color="#0D3A60"/>

    <!-- ── Keyboard badge (hotkey display) ── -->
    <SolidColorBrush x:Key="KbdBadgeBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="KbdBadgeBorder" Color="#555555"/>

    <!-- ── Hotkey recording prompt ── -->
    <SolidColorBrush x:Key="HotkeyRecordingBorder" Color="#0078D4"/>
    <SolidColorBrush x:Key="HotkeyRecordingBackground" Color="#0D2A40"/>
    <SolidColorBrush x:Key="HotkeyRecordingText" Color="#60AAEE"/>

    <!-- ── Annotation overlay toolbar ── -->
    <SolidColorBrush x:Key="ToolbarBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="ToolbarBorder" Color="#444444"/>
    <SolidColorBrush x:Key="ToolBtnCheckedBackground" Color="#0D3A60"/>
    <SolidColorBrush x:Key="ToolBtnCheckedBorder" Color="#0078D4"/>
    <SolidColorBrush x:Key="ToolBtnHoverBackground" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ActionBtnHoverBackground" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ActionBtnPressedBackground" Color="#0D3A60"/>
    <SolidColorBrush x:Key="OcrLassoFill" Color="#150078D4"/>

</ResourceDictionary>
