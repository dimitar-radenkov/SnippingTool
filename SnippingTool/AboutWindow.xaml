<Window x:Class="SnippingTool.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About SnippingTool"
        Width="360" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="White"
        Icon="/Assets/icon.ico">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: icon + name -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="/Assets/icon.ico" Width="48" Height="48"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   VerticalAlignment="Center" Margin="0,0,14,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="SnippingTool"
                           FontSize="20" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                <TextBlock x:Name="VersionText"
                           FontSize="12" Foreground="#666666" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="0,0,0,0">
            <TextBlock Text="A lightweight screen capture and annotation tool."
                       FontSize="12" Foreground="#444444" TextWrapping="Wrap" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Changelog: " FontSize="12" Foreground="#444444" VerticalAlignment="Center"/>
                <TextBlock FontSize="12" VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/dimitar-radenkov/SnippingTool/releases"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        github.com/…/releases
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Source: " FontSize="12" Foreground="#444444" VerticalAlignment="Center"/>
                <TextBlock FontSize="12" VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/dimitar-radenkov/SnippingTool"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        github.com/dimitar-radenkov/SnippingTool
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Footer button -->
        <Button Grid.Row="2"
                Content="Close"
                HorizontalAlignment="Right"
                Padding="22,6"
                Background="#0078D4"
                Foreground="White"
                BorderThickness="0"
                FontSize="13"
                Cursor="Hand"
                Click="Close_Click"/>
    </Grid>
</Window>
