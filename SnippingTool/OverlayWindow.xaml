<Window x:Class="SnippingTool.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Cursor="Cross"
        ShowInTaskbar="False">

  <Window.Resources>

    <!-- Annotation tool radio button -->
    <Style x:Key="ToolBtn" TargetType="RadioButton">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Margin" Value="0,1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="1"
                    CornerRadius="4" Padding="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#DCE9F9"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#E4E4E4"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsChecked" Value="True"/>
                  <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Bd" Property="Background" Value="#C5DEFA"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Action / icon button -->
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="1"
                    CornerRadius="4" Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#E0E0E0"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#C8DEFA"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <!-- Root canvas — near-transparent so WPF hit-tests it (fully transparent = no hit-test) -->
  <Canvas x:Name="Root" Background="#01000000">

    <!-- ── Phase 1: single full-screen dim ── -->
    <Rectangle x:Name="DimFull" Fill="#80000000"/>

    <!-- ── Phase 2: four dim strips around the selection ── -->
    <Rectangle x:Name="DimTop"    Fill="#80000000" Visibility="Collapsed"/>
    <Rectangle x:Name="DimBottom" Fill="#80000000" Visibility="Collapsed"/>
    <Rectangle x:Name="DimLeft"   Fill="#80000000" Visibility="Collapsed"/>
    <Rectangle x:Name="DimRight"  Fill="#80000000" Visibility="Collapsed"/>

    <!-- Dashed selection border (both phases) -->
    <Rectangle x:Name="SelectionBorder"
               Stroke="White" StrokeThickness="1.5"
               StrokeDashArray="5,3"
               Fill="Transparent"
               Visibility="Hidden"/>

    <!-- Size label shown while dragging -->
    <Border x:Name="SizeLabelBorder"
            Background="#CC000000" CornerRadius="3" Padding="5,2"
            Visibility="Hidden">
      <TextBlock x:Name="SizeLabelText"
                 Foreground="White" FontSize="11"
                 FontFamily="Segoe UI" FontWeight="SemiBold"/>
    </Border>

    <!-- Annotation drawing surface (phase 2, sized over the selection) -->
    <Canvas x:Name="AnnotationCanvas"
            Background="#01000000"
            Visibility="Collapsed"/>

    <!-- Vertical annotation toolbar (phase 2, floats right of selection) -->
    <Border x:Name="AnnotToolbar"
            Background="#F2F2F2" CornerRadius="6"
            BorderBrush="#C0C0C0" BorderThickness="1"
            Padding="4,6" Visibility="Collapsed">
      <Border.Effect>
        <DropShadowEffect Color="#444444" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
      </Border.Effect>
      <StackPanel Orientation="Vertical">

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool" IsChecked="True"
                     Tag="Arrow" Click="Tool_Click" ToolTip="Arrow">
          <TextBlock Text="➤" FontSize="14"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Line" Click="Tool_Click" ToolTip="Line">
          <TextBlock Text="╱" FontSize="14"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Rectangle" Click="Tool_Click" ToolTip="Rectangle">
          <Border Width="16" Height="12" BorderBrush="#555" BorderThickness="1.5" Background="Transparent"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Circle" Click="Tool_Click" ToolTip="Circle">
          <TextBlock Text="⬭" FontSize="14"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Pen" Click="Tool_Click" ToolTip="Pen">
          <TextBlock Text="✏" FontSize="14"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Highlight" Click="Tool_Click" ToolTip="Highlight">
          <Border Width="18" Height="8" Background="#99FFFF00"
                  BorderBrush="#A09010" BorderThickness="1" CornerRadius="1"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Text" Click="Tool_Click" ToolTip="Text">
          <TextBlock Text="T" FontSize="15" FontWeight="Bold"/>
        </RadioButton>

        <RadioButton Style="{StaticResource ToolBtn}"
                     GroupName="AnnotTool"
                     Tag="Number" Click="Tool_Click" ToolTip="Place numbered label">
          <TextBlock Text="①" FontSize="15"/>
        </RadioButton>

        <!-- Divider -->
        <Rectangle Height="1" Fill="#D0D0D0" Margin="4,5"/>

        <!-- Color swatch -->
        <Button Width="34" Height="34" Cursor="Hand"
                Style="{StaticResource ActionBtn}"
                Click="ColorBtn_Click" ToolTip="Colour">
          <Ellipse x:Name="ColorDot" Width="20" Height="20" Fill="Red"/>
        </Button>

      </StackPanel>
    </Border>

    <!-- Horizontal action bar (phase 2, floats below selection) -->
    <Border x:Name="ActionBar"
            Background="#F2F2F2" CornerRadius="6"
            BorderBrush="#C0C0C0" BorderThickness="1"
            Padding="6,4" Visibility="Collapsed">
      <Border.Effect>
        <DropShadowEffect Color="#444444" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
      </Border.Effect>
      <StackPanel Orientation="Horizontal">

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)">
          <StackPanel>
            <TextBlock Text="↩" FontSize="13" HorizontalAlignment="Center"/>
            <TextBlock Text="Undo" FontSize="8" Foreground="#555" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="#D0D0D0" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)">
          <StackPanel>
            <TextBlock Text="↪" FontSize="13" HorizontalAlignment="Center"/>
            <TextBlock Text="Redo" FontSize="8" Foreground="#555" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="#D0D0D0" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Click="Copy_Click" ToolTip="Copy to clipboard (Ctrl+C)">
          <StackPanel>
            <TextBlock Text="📋" FontSize="13" HorizontalAlignment="Center"/>
            <TextBlock Text="Copy" FontSize="8" Foreground="#555" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Fill="#D0D0D0" Margin="3,7" VerticalAlignment="Stretch"/>

        <Button Style="{StaticResource ActionBtn}"
                Click="CloseBtn_Click" ToolTip="Close (Esc)">
          <StackPanel>
            <TextBlock Text="✕" FontSize="13" HorizontalAlignment="Center"/>
            <TextBlock Text="Close" FontSize="8" Foreground="#555" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

      </StackPanel>
    </Border>

  </Canvas>
</Window>
