<Window x:Class="SnippingTool.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snipping Tool"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        MinWidth="300" MinHeight="160"
        KeyDown="Window_KeyDown">

  <Window.Resources>

    <!-- Annotation tool RadioButton — flat icon+label -->
    <Style x:Key="ToolBtn" TargetType="RadioButton">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="1"
                    CornerRadius="4" Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#DCE9F9"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#EEEEEE"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsChecked" Value="True"/>
                  <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Bd" Property="Background" Value="#C5DEFA"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Action button — Copy / Save -->
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="1"
                    CornerRadius="4" Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#EEEEEE"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#DCE9F9"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Color dot button -->
    <Style x:Key="ColorDotBtn" TargetType="Button">
      <Setter Property="Width" Value="32"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="3,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" CornerRadius="16" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="#BBBBBB"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Close (X) button — red on hover -->
    <Style x:Key="CloseBtn" TargetType="Button">
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="44"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="#444444"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="0,6,0,0">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#C40000"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Toolbar vertical divider -->
    <Style x:Key="Divider" TargetType="Rectangle">
      <Setter Property="Width" Value="1"/>
      <Setter Property="Fill" Value="#DDDDDD"/>
      <Setter Property="Margin" Value="4,8"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

  </Window.Resources>

  <!-- Margin creates space for the drop-shadow to bleed outside the border -->
  <Grid Margin="8">

    <Border x:Name="ChromeBorder"
            CornerRadius="6"
            Background="White"
            BorderBrush="#C8C8C8"
            BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect Color="#333333" BlurRadius="12" ShadowDepth="0" Opacity="0.30"/>
      </Border.Effect>

      <DockPanel>

        <!-- ══════════════════ Toolbar ══════════════════ -->
        <Border DockPanel.Dock="Top"
                x:Name="Toolbar"
                Height="46"
                Background="#F8F8F8"
                BorderBrush="#E4E4E4"
                BorderThickness="0,0,0,1"
                Cursor="SizeAll"
                MouseLeftButtonDown="Toolbar_MouseDown">

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Annotation tools + colour + thickness -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="6,0,0,0">

              <!-- Arrow -->
              <RadioButton x:Name="ArrowTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool"
                           Tag="Arrow" Click="Tool_Click" ToolTip="Draw arrow">
                <StackPanel>
                  <TextBlock Text="➤" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Arrow" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <!-- Rectangle (outline only) -->
              <RadioButton x:Name="RectTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool" IsChecked="True"
                           Tag="Rectangle" Click="Tool_Click" ToolTip="Draw rectangle">
                <StackPanel>
                  <Border Width="18" Height="12" BorderBrush="#555" BorderThickness="2"
                          Background="Transparent" HorizontalAlignment="Center" Margin="0,3,0,1"/>
                  <TextBlock Text="Rect" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <!-- Text -->
              <RadioButton x:Name="TextTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool"
                           Tag="Text" Click="Tool_Click" ToolTip="Add text">
                <StackPanel>
                  <TextBlock Text="T" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  <TextBlock Text="Text" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <!-- Highlight -->
              <RadioButton x:Name="HighlightTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool"
                           Tag="Highlight" Click="Tool_Click" ToolTip="Highlight">
                <StackPanel>
                  <Border Width="20" Height="9" Background="#90FFFF00"
                          BorderBrush="#A0960C" BorderThickness="1"
                          CornerRadius="1" HorizontalAlignment="Center" Margin="0,3,0,1"/>
                  <TextBlock Text="Hilite" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <!-- Pen -->
              <RadioButton x:Name="PenTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool"
                           Tag="Pen" Click="Tool_Click" ToolTip="Freehand pen">
                <StackPanel>
                  <TextBlock Text="✏" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Pen" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <!-- Line -->
              <RadioButton x:Name="LineTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool"
                           Tag="Line" Click="Tool_Click" ToolTip="Draw line">
                <StackPanel>
                  <TextBlock Text="╱" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Line" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <!-- Circle -->
              <RadioButton x:Name="CircleTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool"
                           Tag="Circle" Click="Tool_Click" ToolTip="Draw circle / ellipse">
                <StackPanel>
                  <TextBlock Text="⬭" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Circle" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <!-- Number -->
              <RadioButton x:Name="NumberTool" Style="{StaticResource ToolBtn}"
                           GroupName="Tool"
                           Tag="Number" Click="Tool_Click" ToolTip="Place numbered label">
                <StackPanel>
                  <Border Width="18" Height="18" BorderBrush="#555" BorderThickness="1.5"
                          CornerRadius="9" Background="Transparent"
                          HorizontalAlignment="Center" Margin="0,2,0,0">
                    <TextBlock Text="1" FontSize="9" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#555"/>
                  </Border>
                  <TextBlock Text="Num" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>

              <Rectangle Style="{StaticResource Divider}"/>

              <!-- Colour picker button -->
              <Button x:Name="ColorPickerBtn"
                      Style="{StaticResource ColorDotBtn}"
                      Click="ColorPickerBtn_Click"
                      ToolTip="Colour">
                <Grid Width="22" Height="22">
                  <Ellipse x:Name="ColorIndicator" Width="22" Height="22" Fill="Red"/>
                  <Ellipse Width="22" Height="22" Stroke="#60000000" StrokeThickness="1" Fill="Transparent"/>
                </Grid>
              </Button>

              <!-- Colour popup -->
              <Popup x:Name="ColorPopup"
                     PlacementTarget="{Binding ElementName=ColorPickerBtn}"
                     Placement="Bottom"
                     StaysOpen="False"
                     AllowsTransparency="True">
                <Border Background="White" CornerRadius="6"
                        BorderBrush="#C8C8C8" BorderThickness="1"
                        Padding="8">
                  <Border.Effect>
                    <DropShadowEffect Color="#333333" BlurRadius="8" ShadowDepth="0" Opacity="0.25"/>
                  </Border.Effect>
                  <StackPanel>
                    <WrapPanel Width="120">
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="Red" Tag="Red"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="DodgerBlue" Tag="Blue"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="#1A1A1A" Tag="Black"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="#22A422" Tag="Green"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="Orange" Tag="Orange"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="#8B2BE2" Tag="Purple"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="White" Tag="White"
                              BorderBrush="#CCCCCC" BorderThickness="1"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                      <Border Width="26" Height="26" Margin="3" CornerRadius="4"
                              Background="HotPink" Tag="Pink"
                              Cursor="Hand" MouseLeftButtonDown="Color_Click"/>
                    </WrapPanel>
                    <Button Content="More colours…" Margin="3,4,3,0" Height="24"
                            FontSize="10" Cursor="Hand"
                            Click="ColorMoreBtn_Click"/>
                  </StackPanel>
                </Border>
              </Popup>

              <Rectangle Style="{StaticResource Divider}"/>

              <!-- Stroke thickness -->
              <ComboBox x:Name="StrokeThickness"
                        Width="60" Height="26"
                        Margin="3,0"
                        VerticalAlignment="Center"
                        SelectedIndex="1"
                        SelectionChanged="StrokeThickness_Changed"
                        ToolTip="Line thickness">
                <ComboBoxItem Content="1 px"/>
                <ComboBoxItem Content="2 px"/>
                <ComboBoxItem Content="4 px"/>
                <ComboBoxItem Content="6 px"/>
              </ComboBox>

            </StackPanel>

            <!-- RIGHT: Copy • Save • Close -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,0,0">

              <Rectangle Style="{StaticResource Divider}"/>

              <Button Style="{StaticResource ActionBtn}"
                      Click="Undo_Click" ToolTip="Undo (Ctrl+Z)">
                <StackPanel>
                  <TextBlock Text="↩" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Undo" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button Style="{StaticResource ActionBtn}"
                      Click="Redo_Click" ToolTip="Redo (Ctrl+Y)">
                <StackPanel>
                  <TextBlock Text="↪" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Redo" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Rectangle Style="{StaticResource Divider}"/>

              <Button Style="{StaticResource ActionBtn}"
                      Click="Copy_Click" ToolTip="Copy to clipboard (Ctrl+C)">
                <StackPanel>
                  <TextBlock Text="📋" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Copy" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button Style="{StaticResource ActionBtn}"
                      Click="Save_Click" ToolTip="Save to file">
                <StackPanel>
                  <TextBlock Text="💾" FontSize="13" HorizontalAlignment="Center"/>
                  <TextBlock Text="Save" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Rectangle Style="{StaticResource Divider}"/>

              <Button Style="{StaticResource CloseBtn}"
                      Click="CloseBtn_Click" ToolTip="Close">
                <TextBlock Text="✕" FontSize="13" FontWeight="Medium"/>
              </Button>

            </StackPanel>
          </Grid>
        </Border>

        <!-- ══════════════════ Screenshot + canvas ══════════════════ -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#E8E8E8">
          <Grid x:Name="RootGrid">
            <Image x:Name="SnipImage"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>
            <Canvas x:Name="AnnotationCanvas"
                    Background="Transparent"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"/>
          </Grid>
        </ScrollViewer>

      </DockPanel>
    </Border>
  </Grid>
</Window>