<Window x:Class="SnippingTool.RecordingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Arrow">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <Style x:Key="ToolBtn" TargetType="RadioButton">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Margin" Value="0,1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="1"
                    CornerRadius="4" Padding="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolBtnCheckedBackground}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ToolBtnCheckedBorder}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolBtnHoverBackground}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="RecordingHudActionBtn" TargetType="Button">
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnHoverBackground}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnPressedBackground}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="RecordingHudModeActionBtn" TargetType="Button">
      <Setter Property="Width" Value="60"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{DynamicResource ActionBtnHoverBackground}"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <DataTrigger Binding="{Binding IsAnnotationInputArmed}" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolBtnCheckedBackground}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ToolBtnCheckedBorder}"/>
              </DataTrigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionBtnPressedBackground}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PressedBackground}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Canvas x:Name="Root" Background="#01000000">
    <Rectangle x:Name="RecordingBorderWhite"
               Fill="Transparent"
               Stroke="White"
               StrokeThickness="2"
               IsHitTestVisible="False">
      <Rectangle.StrokeDashArray>
        <DoubleCollection>6 6</DoubleCollection>
      </Rectangle.StrokeDashArray>
    </Rectangle>

    <Rectangle x:Name="RecordingBorderBlack"
               Fill="Transparent"
               Stroke="Black"
               StrokeThickness="2"
               StrokeDashOffset="6"
               IsHitTestVisible="False">
      <Rectangle.StrokeDashArray>
        <DoubleCollection>6 6</DoubleCollection>
      </Rectangle.StrokeDashArray>
    </Rectangle>

    <Canvas x:Name="RecordingCursorEffectsCanvas"
            Background="Transparent"
            IsHitTestVisible="False"/>

    <Canvas x:Name="RecordingAnnotationCanvas"
            Background="#01000000"/>

    <Border x:Name="RecordingHudPanel"
            Background="{DynamicResource ToolbarBackground}"
            CornerRadius="6"
            BorderBrush="{DynamicResource ToolbarBorder}"
            BorderThickness="1"
            Padding="6,4"
            Visibility="Collapsed"
            SizeChanged="RecordingHudPanel_SizeChanged">
      <Border.Effect>
        <DropShadowEffect Color="#444444" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
      </Border.Effect>
      <StackPanel Orientation="Vertical">

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0"
                    Style="{StaticResource RecordingHudModeActionBtn}"
                    Command="{Binding ToggleAnnotationInputCommand}"
                    ToolTip="Switch between drawing and interacting with the app"
                    Visibility="{Binding CanToggleAnnotation, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="✎" FontSize="13" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
            </Button>

            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="{Binding CurrentModeLabel}"
                       FontSize="8"
                       Foreground="{DynamicResource SubLabelText}"
                       TextAlignment="Center"
                       Margin="0,2,0,0"
                       Visibility="{Binding CanToggleAnnotation, Converter={StaticResource BoolToVisibility}}"/>

            <Rectangle Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                       Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"
                       Visibility="{Binding CanToggleAnnotation, Converter={StaticResource BoolToVisibility}}"/>

            <Button Grid.Row="0" Grid.Column="2"
                    Style="{StaticResource RecordingHudActionBtn}"
                    Command="{Binding PauseResumeCommand}"
                    IsEnabled="{Binding CanPauseResume}"
                    ToolTip="Pause or resume recording">
              <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="⏸"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding PauseResumeLabel}" Value="▶ Resume">
                        <Setter Property="Text" Value="▶"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Button>

            <TextBlock Grid.Row="1" Grid.Column="2" FontSize="8" Foreground="{DynamicResource SubLabelText}" TextAlignment="Center" Margin="0,2,0,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="Pause"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding PauseResumeLabel}" Value="▶ Resume">
                      <Setter Property="Text" Value="Resume"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <Rectangle Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>

            <Button Grid.Row="0" Grid.Column="4"
                    Style="{StaticResource RecordingHudActionBtn}"
                    Command="{Binding StopCommand}"
                    ToolTip="Stop recording">
              <TextBlock Text="⏹" FontSize="13" Foreground="#FF4444" HorizontalAlignment="Center"/>
            </Button>

            <TextBlock Grid.Row="1" Grid.Column="4" Text="Stop" FontSize="8" Foreground="{DynamicResource SubLabelText}" TextAlignment="Center" Margin="0,2,0,0"/>
          </Grid>

          <Border Grid.Column="1"
                  Background="{DynamicResource ActionBtnHoverBackground}"
                  CornerRadius="4"
                  Padding="10,0"
                  MinWidth="64"
                  Height="32"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Right">
            <TextBlock Text="{Binding ElapsedText}"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="13"
                       FontFamily="Segoe UI"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
        </Grid>

        <Rectangle Height="1" Fill="{DynamicResource DividerColor}" Margin="0,6,0,0"
                   Visibility="{Binding IsAnnotationPanelVisible, Converter={StaticResource BoolToVisibility}}"/>

        <Grid Margin="0,6,0,0" Visibility="{Binding IsAnnotationPanelVisible, Converter={StaticResource BoolToVisibility}}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
            <RadioButton Style="{StaticResource ToolBtn}" GroupName="RecordingAnnotTool" Tag="Pen" IsChecked="True" Checked="RecordingToolButton_Checked" ToolTip="Pen">
              <TextBlock Text="✏" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>
            </RadioButton>
            <RadioButton Style="{StaticResource ToolBtn}" GroupName="RecordingAnnotTool" Tag="Arrow" Checked="RecordingToolButton_Checked" ToolTip="Arrow">
              <TextBlock Text="➤" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>
            </RadioButton>
            <RadioButton Style="{StaticResource ToolBtn}" GroupName="RecordingAnnotTool" Tag="Rectangle" Checked="RecordingToolButton_Checked" ToolTip="Rectangle">
              <Border Width="16" Height="12" BorderBrush="{DynamicResource SubLabelText}" BorderThickness="1.5" Background="Transparent"/>
            </RadioButton>
            <RadioButton Style="{StaticResource ToolBtn}" GroupName="RecordingAnnotTool" Tag="Text" Checked="RecordingToolButton_Checked" ToolTip="Text">
              <TextBlock Text="T" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
            </RadioButton>
            <RadioButton Style="{StaticResource ToolBtn}" GroupName="RecordingAnnotTool" Tag="Blur" Checked="RecordingToolButton_Checked" ToolTip="Blur / Redact">
              <TextBlock Text="▒" FontSize="16" Foreground="{DynamicResource PrimaryText}"/>
            </RadioButton>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="8,0,0,0" HorizontalAlignment="Right">
            <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>
            <Button Style="{StaticResource RecordingHudActionBtn}" Command="{Binding UndoAnnotationsCommand}" ToolTip="Undo annotation">
              <TextBlock Text="↩" FontSize="13" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
            </Button>
            <Rectangle Width="1" Fill="{DynamicResource DividerColor}" Margin="3,7" VerticalAlignment="Stretch"/>
            <Button Style="{StaticResource RecordingHudActionBtn}" Command="{Binding ClearAnnotationsCommand}" ToolTip="Clear annotations">
              <TextBlock Text="✕" FontSize="13" Foreground="#D96464" HorizontalAlignment="Center"/>
            </Button>
          </StackPanel>
        </Grid>

        <TextBlock Text="{Binding SavedFileName}"
                   Foreground="{DynamicResource AccentColor}"
                   FontSize="11"
                   FontFamily="Segoe UI"
                   Cursor="Hand"
                   Margin="0,6,0,0"
                   Visibility="{Binding IsStopped, Converter={StaticResource BoolToVisibility}}"
                   MouseLeftButtonUp="RecordingSavedText_Click"/>

        <Button Style="{StaticResource RecordingHudActionBtn}"
                Command="{Binding ExportToGifCommand}"
                Margin="0,4,0,0"
                HorizontalAlignment="Left"
                Width="Auto"
                Visibility="{Binding IsStopped, Converter={StaticResource BoolToVisibility}}"
                ToolTip="Export recording as animated GIF">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="🎞" FontSize="12" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock FontSize="11" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="Export as GIF"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExportingGif}" Value="True">
                      <Setter Property="Text" Value="Exporting…"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
        </Button>

        <TextBlock Text="{Binding GifExportStatusText}"
                   FontSize="11"
                   FontFamily="Segoe UI"
                   Margin="0,4,0,0"
                   Cursor="Hand"
                   Visibility="{Binding IsGifExportStatusVisible, Converter={StaticResource BoolToVisibility}}"
                   MouseLeftButtonUp="RecordingSavedText_Click">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsGifExportStatusError}" Value="True">
                  <Setter Property="Foreground" Value="#D96464"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>
    </Border>
  </Canvas>

  <Window.Triggers>
    <EventTrigger RoutedEvent="Loaded">
      <BeginStoryboard>
        <Storyboard RepeatBehavior="Forever">
          <DoubleAnimation Storyboard.TargetName="RecordingBorderWhite"
                           Storyboard.TargetProperty="StrokeDashOffset"
                           From="0"
                           To="-12"
                           Duration="0:0:0.5"/>
          <DoubleAnimation Storyboard.TargetName="RecordingBorderBlack"
                           Storyboard.TargetProperty="StrokeDashOffset"
                           From="6"
                           To="-6"
                           Duration="0:0:0.5"/>
        </Storyboard>
      </BeginStoryboard>
    </EventTrigger>
  </Window.Triggers>
</Window>