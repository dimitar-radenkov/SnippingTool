<Window x:Class="SnippingTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:SnippingTool.Models"
        Title="Settings"
        Width="540" Height="650"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="White">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="155"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="BorderBrush" Value="#C0C0C0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#C0C0C0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="22,6"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="22,6"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#C0C0C0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

            <!-- Screenshot section -->
            <TextBlock Text="Screenshot" Style="{StaticResource SectionHeader}"/>
            <Border Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="12,10" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Save folder" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="210"
                                 Text="{Binding ScreenshotSavePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Browse…" Style="{StaticResource BrowseBtn}"
                                Command="{Binding BrowseScreenshotPathCommand}"
                                Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Auto-save on copy" Style="{StaticResource RowLabel}"/>
                        <CheckBox IsChecked="{Binding AutoSaveScreenshots}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Capture delay (sec)" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="70"
                                  SelectedItem="{Binding CaptureDelaySeconds}">
                            <sys:Int32>0</sys:Int32>
                            <sys:Int32>3</sys:Int32>
                            <sys:Int32>5</sys:Int32>
                            <sys:Int32>10</sys:Int32>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recording section -->
            <TextBlock Text="Recording" Style="{StaticResource SectionHeader}"/>
            <Border Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="12,10" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Output folder" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="210"
                                 Text="{Binding RecordingOutputPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Browse…" Style="{StaticResource BrowseBtn}"
                                Command="{Binding BrowseRecordingPathCommand}"
                                Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Output format" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="100"
                                  SelectedItem="{Binding RecordingFormat}"
                                  ItemsSource="{Binding Source={x:Static models:RecordingFormatValues.All}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Frames per second" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="60"
                                 Text="{Binding RecordingFps, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="IntInput_PreviewTextInput"
                                 DataObject.Pasting="IntInput_Pasting"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="JPEG quality (1–100)" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="60"
                                 Text="{Binding RecordingJpegQuality, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="IntInput_PreviewTextInput"
                                 DataObject.Pasting="IntInput_Pasting"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="HUD close delay (sec)" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="60"
                                 Text="{Binding HudCloseDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="IntInput_PreviewTextInput"
                                 DataObject.Pasting="IntInput_Pasting"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Annotation defaults section -->
            <TextBlock Text="Annotation defaults" Style="{StaticResource SectionHeader}"/>
            <Border Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="12,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Default color" Style="{StaticResource RowLabel}"/>
                        <Border Width="32" Height="24" BorderBrush="#C0C0C0" BorderThickness="1"
                                CornerRadius="3"
                                Background="{Binding ColorPreviewBrush}"/>
                        <Button Content="Change…" Style="{StaticResource BrowseBtn}"
                                Command="{Binding PickAnnotationColorCommand}"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Stroke thickness" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="60"
                                 Text="{Binding DefaultStrokeThickness, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="DoubleInput_PreviewTextInput"
                                 DataObject.Pasting="DoubleInput_Pasting"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Hotkeys section -->
            <TextBlock Text="Hotkeys" Style="{StaticResource SectionHeader}" Margin="0,14,0,6"/>
            <Border Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="12,10">
                <StackPanel>

                    <!-- Idle state: kbd badge + Change + Reset -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecordingHotkey}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Region capture key" Style="{StaticResource RowLabel}"/>
                        <Border Background="#F0F0F0" BorderBrush="#AAAAAA" BorderThickness="1,1,1,3"
                                CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                            <TextBlock Text="{Binding RegionCaptureHotkeyDisplayName}"
                                       FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                        </Border>
                        <Button Content="Change" Style="{StaticResource BrowseBtn}"
                                Command="{Binding StartRecordingHotkeyCommand}"
                                Margin="0,0,6,0"/>
                        <Button Content="Reset" Style="{StaticResource BrowseBtn}"
                                Command="{Binding ResetHotkeyCommand}"/>
                    </StackPanel>

                    <!-- Recording state: press-a-key prompt -->
                    <StackPanel x:Name="HotkeyRecordingPanel"
                                Orientation="Horizontal"
                                Focusable="True"
                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                IsVisibleChanged="HotkeyRecordingPanel_IsVisibleChanged">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecordingHotkey}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Region capture key" Style="{StaticResource RowLabel}"/>
                        <Border BorderBrush="#0078D4" BorderThickness="2" CornerRadius="4"
                                Padding="10,5" Background="#EFF6FC" Width="200">
                            <TextBlock Text="Press a key…  Esc to cancel"
                                       Foreground="#0078D4" FontStyle="Italic" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryBtn}"
                    Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
            <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>

    </Grid>
</Window>
