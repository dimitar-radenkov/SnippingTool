<Window x:Class="SnippingTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:SnippingTool.Models"
        Title="Settings"
        Width="540"
        SizeToContent="Height"
        ResizeMode="NoResize"
        MaxHeight="750"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBackground}"
        AutomationProperties.AutomationId="SettingsWindow.Root">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Background" Value="{DynamicResource BtnSecondaryBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="22,6"/>
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="22,6"/>
            <Setter Property="Background" Value="{DynamicResource BtnSecondaryBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

            <!-- Screenshot section -->
            <TextBlock Text="Screenshot" Style="{StaticResource SectionHeader}"/>
            <Border Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Save folder" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="210"
                                 Text="{Binding ScreenshotSavePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Browse…" Style="{StaticResource BrowseBtn}"
                                Command="{Binding BrowseScreenshotPathCommand}"
                                Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Auto-save on copy" Style="{StaticResource RowLabel}"/>
                        <CheckBox IsChecked="{Binding AutoSaveScreenshots}"
                                  AutomationProperties.AutomationId="SettingsWindow.AutoSaveScreenshots"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Capture delay (sec)" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="70"
                                  SelectedItem="{Binding CaptureDelaySeconds}">
                            <sys:Int32>0</sys:Int32>
                            <sys:Int32>3</sys:Int32>
                            <sys:Int32>5</sys:Int32>
                            <sys:Int32>10</sys:Int32>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recording section -->
            <TextBlock Text="Recording" Style="{StaticResource SectionHeader}"/>
            <Border Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Output folder" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="210"
                                 Text="{Binding RecordingOutputPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Browse…" Style="{StaticResource BrowseBtn}"
                                Command="{Binding BrowseRecordingPathCommand}"
                                Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Output format" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="100"
                                  SelectedItem="{Binding RecordingFormat}"
                                  ItemsSource="{Binding Source={x:Static models:RecordingFormatValues.All}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Cursor highlight" Style="{StaticResource RowLabel}"/>
                        <CheckBox IsChecked="{Binding RecordingCursorHighlightEnabled}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Click ripple" Style="{StaticResource RowLabel}"/>
                        <CheckBox IsChecked="{Binding RecordingClickRippleEnabled}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Highlight size" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="60"
                                 Text="{Binding RecordingCursorHighlightSize, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="DoubleInput_PreviewTextInput"
                                 DataObject.Pasting="DoubleInput_Pasting"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="GIF export FPS" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="70"
                                  SelectedItem="{Binding GifFps}">
                            <sys:Int32>5</sys:Int32>
                            <sys:Int32>8</sys:Int32>
                            <sys:Int32>10</sys:Int32>
                            <sys:Int32>15</sys:Int32>
                            <sys:Int32>20</sys:Int32>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Annotation defaults section -->
            <TextBlock Text="Annotation defaults" Style="{StaticResource SectionHeader}"/>
            <Border Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Default color" Style="{StaticResource RowLabel}"/>
                        <Border Width="32" Height="24" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1"
                                CornerRadius="3"
                                Background="{Binding ColorPreviewBrush}"/>
                        <Button Content="Change…" Style="{StaticResource BrowseBtn}"
                                Command="{Binding PickAnnotationColorCommand}"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Stroke thickness" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="60"
                                 Text="{Binding DefaultStrokeThickness, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="DoubleInput_PreviewTextInput"
                                 DataObject.Pasting="DoubleInput_Pasting"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Hotkeys section -->
            <TextBlock Text="Hotkeys" Style="{StaticResource SectionHeader}" Margin="0,10,0,6"/>
            <Border Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8">
                <StackPanel>

                    <!-- Idle state: kbd badge + Change + Reset -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecordingHotkey}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Region capture key" Style="{StaticResource RowLabel}"/>
                        <Border Background="{DynamicResource KbdBadgeBackground}" BorderBrush="{DynamicResource KbdBadgeBorder}" BorderThickness="1,1,1,3"
                                CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                            <TextBlock Text="{Binding RegionCaptureHotkeyDisplayName}"
                                       FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryText}"/>
                        </Border>
                        <Button Content="Change" Style="{StaticResource BrowseBtn}"
                                Command="{Binding StartRecordingHotkeyCommand}"
                                Margin="0,0,6,0"/>
                        <Button Content="Reset" Style="{StaticResource BrowseBtn}"
                                Command="{Binding ResetHotkeyCommand}"/>
                    </StackPanel>

                    <!-- Recording state: press-a-key prompt -->
                    <StackPanel x:Name="HotkeyRecordingPanel"
                                Orientation="Horizontal"
                                Focusable="True"
                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                IsVisibleChanged="HotkeyRecordingPanel_IsVisibleChanged">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecordingHotkey}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Region capture key" Style="{StaticResource RowLabel}"/>
                        <Border BorderBrush="{DynamicResource HotkeyRecordingBorder}" BorderThickness="2" CornerRadius="4"
                                Padding="10,5" Background="{DynamicResource HotkeyRecordingBackground}" Width="200">
                            <TextBlock Text="Press a key…  Esc to cancel"
                                       Foreground="{DynamicResource HotkeyRecordingText}" FontStyle="Italic" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Theme section -->
            <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}" Margin="0,10,0,6"/>
            <Border Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Theme" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="170"
                                  SelectedValue="{Binding AppTheme}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="Follow system" Tag="{x:Static models:AppTheme.System}"/>
                            <ComboBoxItem Content="Light"         Tag="{x:Static models:AppTheme.Light}"/>
                            <ComboBoxItem Content="Dark"          Tag="{x:Static models:AppTheme.Dark}"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Updates section -->
            <TextBlock Text="Updates" Style="{StaticResource SectionHeader}" Margin="0,10,0,6"/>
            <Border Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Auto-check interval" Style="{StaticResource RowLabel}"/>
                        <ComboBox x:Name="UpdateIntervalComboBox" Width="170"
                                  SelectedValue="{Binding AutoUpdateCheckInterval}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="Never" Tag="{x:Static models:UpdateCheckInterval.Never}"/>
                            <ComboBoxItem Content="Every day" Tag="{x:Static models:UpdateCheckInterval.EveryDay}"/>
                            <ComboBoxItem Content="Every 2 days" Tag="{x:Static models:UpdateCheckInterval.EveryTwoDays}"/>
                            <ComboBoxItem Content="Every 3 days" Tag="{x:Static models:UpdateCheckInterval.EveryThreeDays}"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Text="&#x26A0;&#xFE0F;  Automatic updates are disabled. You may miss important fixes."
                               Foreground="{DynamicResource WarningText}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AutoUpdateCheckInterval}"
                                                 Value="{x:Static models:UpdateCheckInterval.Never}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryBtn}"
                    Margin="0,0,8,0" Command="{Binding CancelCommand}"
                    AutomationProperties.AutomationId="SettingsWindow.Cancel"/>
            <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                    Command="{Binding SaveCommand}"
                    AutomationProperties.AutomationId="SettingsWindow.Save"/>
        </StackPanel>

    </Grid>
</Window>
